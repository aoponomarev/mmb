# =============================================================================
# ENVIRONMENT VARIABLES — ШАБЛОН
# =============================================================================
# Скопируй этот файл в .env и заполни значения для своей машины.
# .env НЕ коммитится в git (должен быть добавлен в .gitignore).
# .env.example КОММИТИТСЯ — это шаблон без секретов.
# =============================================================================

# =============================================================================
# 1. Cloudflare Parity Contract
# =============================================================================
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_D1_DATABASE_ID=your_cloudflare_d1_database_id

# =============================================================================
# 2. Yandex Cloud & Postgres Gateway
# =============================================================================
DB_HOST=rc1b-dgs1vgc130gbme2n.mdb.yandexcloud.net
DB_PORT=6432
DB_NAME=app_db
DB_USER=app_admin
DB_PASSWORD=your_db_password
YANDEX_API_KEY=your_yandex_api_key

# =============================================================================
# 3. AI Providers
# =============================================================================
MISTRAL_API_KEY=your_mistral_api_key
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# =============================================================================
# 4. Data Providers
# =============================================================================
COINGECKO_API_KEY=your_coingecko_api_key

# =============================================================================
# 5. Infrastructure & Security
# =============================================================================
# Shared datasets safety contract: only one app is active writer at a time (TARGET, LEGACY)
DATA_PLANE_ACTIVE_APP=TARGET

# Local encrypted archive key for Secret Resilience (required for secret backup/restore/integrity checks)
# Generate a long random value (>= 32 chars) and keep it ONLY in local .env (never commit real value).
SYS_SECRET_ARCHIVE_KEY=0cr1kmr2yfv3nrhsnbqxelys[u4n5dbngh6cdtotymzle[
