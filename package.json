{
  "name": "app",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0 <19.0.0"
  },
  "scripts": {
    "test": "node is/scripts/infrastructure/run-node-tests.js",
    "frontend:reactivity:check": "node --test is/scripts/tests/check-frontend-rrg.test.js",
    "preflight": "node is/scripts/preflight.js",
    "health-check": "node is/scripts/infrastructure/health-check.js",
    "health-check:json": "node is/scripts/infrastructure/health-check.js --json",
    "ssot:check": "node is/scripts/infrastructure/validate-ssot.js",
    "env:check": "node is/scripts/infrastructure/validate-env-example.js",
    "env:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-dev-env.ps1",
    "monitoring:snapshot": "node is/scripts/infrastructure/collect-monitoring-snapshot.js",
    "monitoring:baseline": "node is/scripts/infrastructure/check-monitoring-baseline.js",
    "validate:single-writer": "node is/scripts/infrastructure/validate-single-writer.js",
    "single-writer:switch": "node is/scripts/infrastructure/switch-active-writer.js",
    "skills:check": "node is/scripts/architecture/validate-skills.js",
    "md:ids:assign": "node is/scripts/architecture/assign-missing-md-ids.js",
    "md:ids:validate": "node is/scripts/architecture/validate-global-md-ids.js",
    "md:links:validate": "node is/scripts/architecture/validate-id-contract-links.js",
    "docs:links:audit": "node is/scripts/architecture/audit-path-centric-doc-links.js",
    "skills:links:audit": "node is/scripts/architecture/audit-path-centric-skill-links.js",
    "skills:anchors:check": "node is/scripts/architecture/validate-skill-anchors.js",
    "skills:affected": "node is/scripts/architecture/validate-affected-skills.js",
    "skills:batch-review": "node is/scripts/architecture/skills-batch-review.js",
    "skills:create": "node is/scripts/architecture/create-skill.js",
    "skills:reasoning:check": "node is/scripts/architecture/validate-reasoning.js",
    "skills:causality:check": "node is/scripts/architecture/validate-causality.js",
    "skills:index": "node is/scripts/architecture/generate-skills-index.js",
    "ais:index": "node is/scripts/architecture/generate-index-ais.js",
    "ais:index:watch": "node is/scripts/architecture/watch-index-ais.js",
    "docs:encoding:validate": "node is/scripts/architecture/validate-docs-encoding.js",
    "encoding:normalize": "node is/scripts/architecture/normalize-text-encoding.js",
    "docs:ids:validate": "node is/scripts/architecture/validate-docs-ids.js",
    "docs:deletion:validate": "node is/scripts/architecture/validate-deletion-log.js",
    "docs:ids:registry": "node is/scripts/architecture/generate-id-registry.js",
    "ids:orphan:audit": "node is/scripts/architecture/audit-orphan-ids.js",
    "skills:health:trend": "node is/scripts/architecture/skills-health-trend.js",
    "skills:health:trend:report": "node is/scripts/architecture/skills-health-trend-report.js",
    "readmes:check": "node is/scripts/architecture/validate-readmes.js",
    "readmes:sync": "node is/scripts/architecture/sync-readmes.js",
    "lang:comments:check": "node is/scripts/architecture/validate-code-comments-english.js",
    "file-headers:check": "node is/scripts/architecture/validate-file-headers.js",
    "file-headers:fix": "node is/scripts/architecture/assign-file-ids.js && node is/scripts/architecture/validate-file-headers.js --fix",
    "file-headers:audit": "node is/scripts/architecture/assign-file-ids.js && node is/scripts/architecture/validate-file-headers.js --fix",
    "file-headers:assign": "node is/scripts/architecture/assign-file-ids.js",
    "lang:translate": "node is/scripts/architecture/translate-comments-to-english.js",
    "evolution:update": "node is/scripts/architecture/project-evolution-update.js",
    "evolution:rebuild": "node is/scripts/architecture/project-evolution-update.js --rebuild",
    "cache:integrity:check": "node is/scripts/infrastructure/validate-cache-integrity.js",
    "cache:integrity:delta": "node is/scripts/infrastructure/validate-cache-integrity-delta.js",
    "market:http:start": "node is/scripts/infrastructure/start-market-snapshot-server.js",
    "secret:backup": "node is/scripts/secrets/secret-resilience.js --backup",
    "secret:restore": "node is/scripts/secrets/secret-resilience.js --restore-latest",
    "secret:check": "node is/scripts/secrets/secret-resilience.js",
    "testing:premerge": "node is/scripts/infrastructure/check-testing-matrix.js --mode premerge",
    "testing:release": "node is/scripts/infrastructure/check-testing-matrix.js --mode release",
    "testing:ci": "node is/scripts/infrastructure/check-testing-matrix.js --mode ci"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "espree": "^11.1.1",
    "playwright": "^1.58.2"
  }
}
